# Copy this to .env.local and fill in values from your Supabase project.
# When these are missing the app silently uses localStorage only.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional: change if you want a different "room" of synced data.
VITE_TRIP_ID=miami-2026
